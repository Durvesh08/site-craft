{
  "buildCommand": "pnpm run build:frontend",
  "outputDirectory": "artifacts/sitecraft/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://site-craft-4o6p.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
